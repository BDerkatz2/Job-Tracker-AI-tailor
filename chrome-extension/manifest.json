{
  "manifest_version": 3,
  "name": "Job Tracker Extension",
  "version": "1.0",
  "description": "Auto-save job postings to Job Tracker",
  "permissions": ["activeTab", "storage", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Save Job Posting"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.linkedin.com/jobs/*",
        "*://*.linkedin.com/viewjob/*",
        "*://*.indeed.com/viewjob*",
        "*://*.indeed.com/companies/*/jobs/*",
        "*://*.indeed.com/job/*",
        "*://*.indeed.com/jobs/*",
        "*://*.glassdoor.com/job-listing/*",
        "*://*.glassdoor.com/Job/*"
      ],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}